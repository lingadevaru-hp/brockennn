{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "artifacts/fictional-wiki/dist/public",
        "buildCommand": "pnpm --filter @workspace/fictional-wiki run typecheck && pnpm --filter @workspace/fictional-wiki run build"
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/artifacts/fictional-wiki/dist/public/$1" }
  ]
}

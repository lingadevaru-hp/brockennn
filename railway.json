{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm install && pnpm --filter @workspace/fictional-wiki run build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @workspace/fictional-wiki run serve",
    "healthcheckPath": "/",
    "multiRegionConfig": {
      "us-west2": {
        "numReplicas": 1
      }
    }
  }
}
